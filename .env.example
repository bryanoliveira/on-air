# Generate with: openssl rand -hex 32
ON_AIR_API_TOKEN=replace-with-a-random-token
ON_AIR_PORT_BIND=8080:8080

# Optional event hook. Leave ON_AIR_HOOKS empty to disable all hooks.
ON_AIR_HOOKS=
ON_AIR_HOMEASSISTANT_URL=
ON_AIR_HOMEASSISTANT_TOKEN=
# Copy the light.* entity ID from Home Assistant; do not use its display name.
ON_AIR_HOMEASSISTANT_LIGHT_ENTITY_ID=
ON_AIR_HOMEASSISTANT_TIMEZONE=America/Sao_Paulo
ON_AIR_HOMEASSISTANT_CAMERA_COLOR=255,0,0
ON_AIR_HOMEASSISTANT_MIC_COLOR=0,255,0
ON_AIR_HOMEASSISTANT_NIGHT_COLOR=255,160,0
# Optional integer from 1 to 255; blank preserves/defaults brightness.
ON_AIR_HOMEASSISTANT_BRIGHTNESS=
ON_AIR_HOMEASSISTANT_TIMEOUT_SECONDS=5
